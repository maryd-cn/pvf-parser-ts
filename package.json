    "configuration": {
      "title": "PVF Pack Explorer",
      "properties": {
        "pvf.npkRoot": {
          "type": "string",
          "default": "",
          "description": "NPK 文件根目录（通常为游戏目录下的 ImagePacks2）。"
        },
        "pvf.showScriptDisplayName": {
          "type": "boolean",
          "default": true,
          "description": "在 PVF 资源树中文件后追加脚本显示名（来自 .lst 解析）。"
        },
        "pvf.showScriptCode": {
          "type": "boolean",
          "default": true,
          "description": "在 PVF 资源树中文件后追加 <代码>（来自 .lst 解析）。"
        },
        "pvf.metadata.excludeExtensions": {
          "type": "string",
          "default": ".nut,.lst,.ani,.ani.als,.als,.ui,.png,.jpg,.jpeg,.dds,.bmp,.tga,.gif,.wav,.ogg,.mp3,.bin",
          "description": "解析 [name] 标签时要排除的扩展名（逗号/空格/分号分隔）。其他所有文件都会扫描其文本前 32KB 是否含 [name]。"
        },
        "pvf.encodingMode": {
          "type": "string",
          "enum": [
            "AUTO",
            "KR",
            "TW",
            "CN",
            "JP",
            "UTF8"
          ],
          "default": "AUTO",
          "description": "文本解码基准：KR=cp949, TW=big5, CN=gb18030, JP=shift_jis, UTF8=utf8；AUTO 时保持原逻辑 (.nut=cp949 其他=big5)。影响读取/写入文本与 stringtable。"
        },
        "pvf.closeVirtualEditorsOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "启动/重载 VS Code 时自动关闭上次遗留的 pvf: 虚拟文件标签页，防止自动恢复。"
        },
        "pvf.script.convertStringLink": {
          "type": "boolean",
          "default": true,
          "description": "解析器 :: 自动转换字符串链接 <id::name`文字`> 为 `文字`。关闭后仍保留链接形式 (文本被清空为 `` )。"
        },
        "pvf.scriptTagComment.author": {
          "type": "string",
          "default": "Lancarus",
          "description": "编辑脚本标签注释时写入 authors 字段的作者名。默认使用当前项目的 GitHub ID。"
        },
        "pvf.unpack.writeConcurrency": {
          "type": "number",
          "default": 512,
          "minimum": 1,
          "maximum": 2048,
          "description": "解封 PVF 时并发写文件数量。机械硬盘建议 64-128，SSD/NVMe 可尝试 256-512。"
        },
        "pvf.unpack.workerCount": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "maximum": 32,
          "description": "解封 PVF 时用于写盘的 worker 数量。0 表示使用 Node 默认异步写入；不同磁盘差异很大，可尝试 8/12/16。"
        },
        "pvf.unpack.writeBatchSize": {
          "type": "number",
          "default": 64,
          "minimum": 1,
          "maximum": 512,
          "description": "解封 PVF 时每个 worker 消息包含的文件数量。小文件很多时建议 64-128。"
        },
        "pvf.unpack.chineseConversion": {
          "type": "string",
          "enum": [
            "tw2cn",
            "off"
          ],
          "default": "tw2cn",
          "description": "解封 PVF 时是否将繁体文本转换为简体。tw2cn 会写入简体文本，并在重新封装时根据 manifest 自动转回繁体。"
        },
        "pvf.unpack.mkdirConcurrency": {
          "type": "number",
          "default": 128,
          "minimum": 1,
          "maximum": 1024,
          "description": "解封 PVF 时并发创建目录数量。"
        },
        "pvf.repack.readConcurrency": {
          "type": "number",
          "default": 192,
          "minimum": 1,
          "maximum": 1024,
          "description": "将目录封装为 PVF 时并发读取/转换文件数量。"
        }
      }
    },
